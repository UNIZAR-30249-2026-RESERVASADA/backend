{
  "name": "reservas-app-server",
  "version": "1.0.0",
  "main": "src/main.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/main.js",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "amqplib": "^0.10.9",
    "bcryptjs": "^3.0.3",
    "express": "^4.19.2",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/application/**/*.js",
      "src/domain/**/*.js",
      "src/infrastructure/repositories/**/*.js",
      "!src/main.js",
      "!src/infrastructure/database/**/*.js",
      "!src/domain/exceptions/**/*.js"
    ]
  }
}