.ruff_cache/
.tox/
pip-wheel-metadata/
*.egg-info/
.eggs/
.wheels/

############################################
# Docker / Compose
############################################
# Local overrides
docker-compose.override.yml

# Docker build artifacts
**/.docker/

############################################
# PostgreSQL / PostGIS (volumes & dumps)
############################################
# If you have local mounted volumes like ./data or ./postgres-data
postgres-data/
pgdata/
data/
db-data/
database-data/

# SQL dumps/backups
*.sql
*.dump
*.backup
*.tar

############################################
# IDEs / Editors
############################################
.vscode/
.idea/
*.iml

############################################
# OS / Misc
############################################
*.pid
*.seed
*.pid.lock

############################################
